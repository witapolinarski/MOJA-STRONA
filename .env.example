# Skopiuj do .env lokalnie lub ustaw w Netlify → Site configuration → Environment variables

ADMIN_PASSWORD=

# Logowanie do SOZ (https://soz.pzss.org.pl) — to samo konto co PORTAL PZSS
PZSS_SOZ_LOGIN=
PZSS_SOZ_PASSWORD=

# Opcjonalnie: klucz bookmarkletu synchronizacji SOZ (domyślnie ADMIN_PASSWORD)
ROSTER_SYNC_SECRET=

# Opcjonalnie: publiczny URL z eksportem listy członków (fallback)
PZSS_ROSTER_URL=
